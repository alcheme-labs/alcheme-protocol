{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alcheme.dev/schemas/extension-manifest.schema.json",
  "title": "Alcheme Extension Manifest",
  "description": "Schema for third-party extension declarations integrated with Alcheme extension lifecycle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "extension_id",
    "display_name",
    "program_id",
    "version",
    "sdk_package",
    "min_core_sdk_version",
    "required_permissions",
    "event_types",
    "parser_contract_version",
    "projection_tables",
    "rollback_strategy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "extension_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
      "description": "Stable extension identifier used in capability catalog and governance records."
    },
    "display_name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "program_id": {
      "type": "string",
      "pattern": "^[1-9A-HJ-NP-Za-km-z]{32,44}$",
      "description": "Solana program id in base58 format."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "sdk_package": {
      "type": "string",
      "pattern": "^@alcheme\\/(sdk|sdk-extension-[a-z0-9][a-z0-9-]{1,63})$"
    },
    "min_core_sdk_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "required_permissions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "IdentityRead",
          "IdentityVerify",
          "IdentityUpdate",
          "ContentRead",
          "ContentValidate",
          "ContentCreate",
          "ContentStatusUpdate",
          "AccessCheck",
          "AccessRuleRead",
          "EventEmit",
          "EventQuery",
          "RegistryDeploy",
          "RegistryUpgrade",
          "ReputationWrite",
          "ContributionRead",
          "CircleExtend"
        ]
      }
    },
    "event_types": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_]{2,63}$"
      }
    },
    "parser_contract_version": {
      "type": "string",
      "pattern": "^v[1-9][0-9]*$"
    },
    "projection_tables": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{1,63}$"
      }
    },
    "rollback_strategy": {
      "type": "string",
      "enum": [
        "disable_parser_and_keep_core_path",
        "disable_extension_and_preserve_existing_projection",
        "rollback_to_previous_manifest_version"
      ]
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "indexer_min_version",
        "query_api_min_version"
      ],
      "properties": {
        "indexer_min_version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        },
        "query_api_min_version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
        }
      }
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 120
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "string",
      "format": "uri"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "suspended"
      ]
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{1,31}$"
      }
    }
  }
}
