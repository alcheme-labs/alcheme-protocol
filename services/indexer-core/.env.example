# Alcheme Indexer Core 环境配置

# 事件源模式:
# - yellowstone: 使用 Yellowstone gRPC
# - local: 使用本地 Solana JSON-RPC 轮询（无 Yellowstone）
INDEXER_EVENT_SOURCE=yellowstone

# Solana RPC 配置 (由多环境系统覆盖)
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Yellowstone gRPC 配置（INDEXER_EVENT_SOURCE=yellowstone 时必填）
YELLOWSTONE_ENDPOINT=https://yellowstone-grpc-url.com
YELLOWSTONE_TOKEN=CHANGE_ME

# 本地轮询模式配置（INDEXER_EVENT_SOURCE=local 时使用）
LOCAL_RPC_POLL_INTERVAL_MS=1500
LOCAL_RPC_MAX_SLOTS_PER_TICK=32
LOCAL_RPC_INITIAL_BACKFILL_SLOTS=32
LOCAL_RPC_MAX_RETRIES_PER_SLOT=3
LOCAL_RPC_MAX_RETRIES_PER_TX=1
LOCAL_RPC_MAX_FAILED_TXS_PER_SLOT=16
LOCAL_RPC_MAX_CONCURRENT_TX_FETCHES=12
LOCAL_RPC_REQUEST_TIMEOUT_MS=4000
LOCAL_FAILED_SLOT_REPLAY_BATCH_SIZE=16
LOCAL_FAILED_SLOT_REPLAY_INTERVAL_MS=5000
LOCAL_FAILED_SLOT_RESOLVED_RETENTION_SECONDS=604800
LOCAL_FAILED_SLOT_PRUNE_INTERVAL_MS=3600000
LOCAL_FAILED_SLOT_PRUNE_BATCH_SIZE=500

# 生产环境默认禁止 local 事件源（应急时才显式打开）
ALLOW_LOCAL_EVENT_SOURCE_IN_PRODUCTION=false

# Program IDs (由多环境系统覆盖)
EVENT_EMITTER_PROGRAM_ID=CHANGE_ME

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/alcheme
DATABASE_MAX_CONNECTIONS=10

# 日志配置
RUST_LOG=info
RUST_BACKTRACE=1

# Metrics 配置
METRICS_PORT=9090
METRICS_ENABLED=true

# 索引器配置
INDEXER_START_SLOT=0
INDEXER_BATCH_SIZE=100
INDEXER_QUEUE_SIZE=1000

# 性能优化
INDEXER_WORKER_THREADS=4
DB_WRITE_BATCH_SIZE=50
DB_WRITE_TIMEOUT_MS=5000
