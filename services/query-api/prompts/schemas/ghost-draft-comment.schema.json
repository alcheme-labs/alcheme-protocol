{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GhostDraftCommentResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suggestions",
    "confidence"
  ],
  "properties": {
    "suggestions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_ref",
          "summary",
          "suggested_text",
          "open_questions"
        ],
        "properties": {
          "target_ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 220
          },
          "suggested_text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1200
          },
          "open_questions": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 220
            }
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 220
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
