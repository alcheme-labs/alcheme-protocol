{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscussionRelevanceJudgment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "semantic_score",
    "quality_score",
    "spam_score",
    "is_on_topic",
    "confidence",
    "rationale"
  ],
  "properties": {
    "semantic_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "spam_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "is_on_topic": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "semantic_facets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fact",
          "explanation",
          "emotion",
          "question",
          "problem",
          "criteria",
          "proposal",
          "summary"
        ]
      },
      "uniqueItems": true
    }
  }
}
