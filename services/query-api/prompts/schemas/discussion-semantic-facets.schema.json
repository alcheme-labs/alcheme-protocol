{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscussionSemanticFacets",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "semantic_facets"
  ],
  "properties": {
    "semantic_facets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fact",
          "explanation",
          "emotion",
          "question",
          "problem",
          "criteria",
          "proposal",
          "summary"
        ]
      },
      "uniqueItems": true
    }
  }
}
