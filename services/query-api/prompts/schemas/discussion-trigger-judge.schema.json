{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DiscussionTriggerDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "should_trigger",
    "recommended_action",
    "reason_code",
    "reason",
    "confidence",
    "risk_flags"
  ],
  "properties": {
    "should_trigger": {
      "type": "boolean"
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "none",
        "notify_only",
        "auto_draft"
      ]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 320
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_flags": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 48
      }
    }
  }
}

