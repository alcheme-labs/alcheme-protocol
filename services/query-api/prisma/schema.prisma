  @@unique([knowledgeId, eventType, version, sourceEventTimestamp])
  @@index([knowledgeId, eventAt(sort: Desc)])
  @@index([eventType, eventAt(sort: Desc)])
  @@map("knowledge_version_events")
}

model KnowledgeContribution {
  id                   Int       @id @default(autoincrement())
  knowledgeId          Int       @map("knowledge_id")
  contributorPubkey    String    @map("contributor_pubkey") @db.VarChar(44)
  contributorHandle    String?   @map("contributor_handle") @db.VarChar(32)
  contributionRole     String    @map("contribution_role") @db.VarChar(32)
  contributionWeightBps Int      @map("contribution_weight_bps")
  contributionWeight   Decimal   @map("contribution_weight") @db.Decimal(10, 4)
  sourceDraftPostId    Int?      @map("source_draft_post_id")
  sourceAnchorId       String?   @map("source_anchor_id") @db.VarChar(128)
  sourcePayloadHash    String?   @map("source_payload_hash") @db.VarChar(64)
  sourceSummaryHash    String?   @map("source_summary_hash") @db.VarChar(64)
  sourceMessagesDigest String?   @map("source_messages_digest") @db.VarChar(64)
  contributorsRoot     String?   @map("contributors_root") @db.VarChar(64)
  contributorsCount    Int?      @map("contributors_count")
  createdAt            DateTime  @default(now()) @map("created_at")
