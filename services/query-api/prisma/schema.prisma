// Prisma Schema - 基于 PostgreSQL Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  handle             String    @unique @db.VarChar(32)
  pubkey             String    @unique @db.VarChar(44)
  displayName        String?   @map("display_name") @db.VarChar(128)
  bio                String?
  avatarUri          String?   @map("avatar_uri")
  bannerUri          String?   @map("banner_uri")
  website            String?   @db.VarChar(256)
  location           String?   @db.VarChar(128)
  metadataUri        String?   @map("metadata_uri")
  
  reputationScore    Decimal   @default(0) @map("reputation_score") @db.Decimal(10, 2)
  followersCount     Int       @default(0) @map("followers_count")
  followingCount     Int       @default(0) @map("following_count")
  postsCount         Int       @default(0) @map("posts_count")
  circlesCount       Int       @default(0) @map("circles_count")

  // Verification Fields (Off-Chain managed)
  email              String?   @unique @db.VarChar(255)
  emailVerified      Boolean   @default(false) @map("email_verified")
  
  twitterId          String?   @unique @map("twitter_id") @db.VarChar(64)
  twitterHandle      String?   @map("twitter_handle") @db.VarChar(32)
  twitterVerified    Boolean   @default(false) @map("twitter_verified")

  verificationLevel  Int       @default(0) @map("verification_level") // 0: None, 1: Email, 2: Twitter, 3: Both
  
  onChainAddress     String    @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  posts              Post[]    @relation("AuthorPosts")
  followers          Follow[]  @relation("Following")
  following          Follow[]  @relation("Follower")
  likes              Like[]
  sentMessages       Message[] @relation("MessageSender")
  receivedMessages   Message[] @relation("MessageRecipient")
  circleMembers      CircleMember[]
  joinRequests       CircleJoinRequest[] @relation("CircleJoinRequestUser")
  reviewedJoinRequests CircleJoinRequest[] @relation("CircleJoinRequestReviewer")
  sentInvites        CircleInvite[] @relation("CircleInviteSender")
  targetedInvites    CircleInvite[] @relation("CircleInviteTarget")
  acceptedInvites    CircleInvite[] @relation("CircleInviteAcceptor")
  membershipEvents   CircleMembershipEvent[] @relation("CircleMembershipEventUser")
  actedMembershipEvents CircleMembershipEvent[] @relation("CircleMembershipEventActor")
  createdCircles     Circle[]  @relation("CircleCreator")
  conversations      Conversation[] @relation("ConversationCreator")
  conversationParticipants ConversationParticipant[]
  authoredKnowledge  Knowledge[] @relation("AuthoredKnowledge")
  draftComments      DraftComment[]
  ghostDraftGenerationsRequested GhostDraftGeneration[] @relation("GhostDraftRequestedBy")
  ghostDraftAcceptances GhostDraftAcceptance[] @relation("GhostDraftAcceptedBy")
  acceptedDraftCandidates DraftCandidateAcceptance[] @relation("DraftCandidateAcceptedBy")
  attemptedDraftCandidateGenerations DraftCandidateGenerationAttempt[] @relation("DraftCandidateAttemptedBy")
  createdAgents      Agent[]    @relation("AgentCreatedBy")
  ownedAgents        Agent[]    @relation("AgentOwner")
  updatedAgentPolicies CircleAgentPolicy[] @relation("AgentPolicyUpdatedBy")
  notifications      Notification[]
  totem              UserTotem?
  crystalEntitlements CrystalEntitlement[] @relation("CrystalEntitlementOwnerUser")
  crystalReceipts    CrystalReceipt[] @relation("CrystalReceiptOwnerUser")
  
  @@index([handle])
  @@index([pubkey])
  @@index([reputationScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([onChainAddress])
  @@map("users")
}

model Post {
  id                 Int       @id @default(autoincrement())
  contentId          String    @unique @map("content_id") @db.VarChar(128)
  authorId           Int       @map("author_id")
  
  text               String?
  contentType        String    @map("content_type") @db.VarChar(32)
  storageUri         String?   @map("storage_uri")
  storageProvider    String?   @map("storage_provider") @db.VarChar(32)
  
  parentPostId       Int?      @map("parent_post_id")
  threadRootId       Int?      @map("thread_root_id")
  repostOfPostId     Int?      @map("repost_of_post_id")
  repostOfAddress    String?   @map("repost_of_address") @db.VarChar(44)
  replyDepth         Int       @default(0) @map("reply_depth")
  
  circleId           Int?      @map("circle_id")
  tags               String[]  @default([])
  
  likesCount         Int       @default(0) @map("likes_count")
  repostsCount       Int       @default(0) @map("reposts_count")
  repliesCount       Int       @default(0) @map("replies_count")
  commentsCount      Int       @default(0) @map("comments_count")
  sharesCount        Int       @default(0) @map("shares_count")
  viewsCount         Int       @default(0) @map("views_count")
  heatScore          Decimal   @default(0) @map("heat_score") @db.Decimal(10, 4)
  
  status             PostStatus @default(Active)
  visibility         Visibility @default(Public)
  v2VisibilityLevel  String?    @map("v2_visibility_level") @db.VarChar(32)
  v2AudienceKind     String?    @map("v2_audience_kind") @db.VarChar(32)
  v2AudienceRef      Int?       @map("v2_audience_ref")
  v2Status           String?    @map("v2_status") @db.VarChar(32)
  isV2Private        Boolean    @default(false) @map("is_v2_private")
  isV2Draft          Boolean    @default(false) @map("is_v2_draft")
  onChainAddress     String    @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  author             User      @relation("AuthorPosts", fields: [authorId], references: [id], onDelete: Cascade)
  parentPost         Post?     @relation("PostReplies", fields: [parentPostId], references: [id], onDelete: SetNull)
  replies            Post[]    @relation("PostReplies")
  threadRoot         Post?     @relation("ThreadRoot", fields: [threadRootId], references: [id], onDelete: SetNull)
  thread             Post[]    @relation("ThreadRoot")
  repostOf           Post?     @relation("PostReposts", fields: [repostOfPostId], references: [id], onDelete: SetNull)
  reposts            Post[]    @relation("PostReposts")
  circle             Circle?   @relation(fields: [circleId], references: [id], onDelete: SetNull)
  likes              Like[]
  draftComments      DraftComment[]
  ghostDraftGenerations GhostDraftGeneration[]
  ghostDraftAcceptances GhostDraftAcceptance[]
  draftCandidateAcceptance DraftCandidateAcceptance?
  draftCandidateGenerationAttempts DraftCandidateGenerationAttempt[]
  
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([v2VisibilityLevel, v2Status])
  @@index([v2AudienceKind, v2AudienceRef])
  @@index([threadRootId])
  @@index([parentPostId])
  @@index([repostOfPostId])
  @@index([circleId])
  @@index([onChainAddress])
  @@map("posts")
}

enum PostStatus {
  Active       // 活跃 (= Published，兼容旧数据)
  Draft        // 草稿
  Published    // 已发布
  Archived     // 已归档
  Deleted      // 已删除
  Moderated    // 审核中
  Suspended    // 已暂停
  Flagged      // 已标记
  UnderReview  // 审核中 (链上状态)
  Hidden       // 隐藏 (客户端侧状态)
}

enum Visibility {
  Public
  CircleOnly
  FollowersOnly
  Private
}

model Circle {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(128)
  description        String?
  avatarUri          String?   @map("avatar_uri")
  bannerUri          String?   @map("banner_uri")
  
  creatorId          Int       @map("creator_id")
  
  circleType         CircleType @default(Open) @map("circle_type")
  joinRequirement    JoinRequirement @default(Free) @map("join_requirement")
  
  // 层级结构
  level              Int       @default(0)  // 0=Plaza, 1=Crucible, 2=Sanctuary
  parentCircleId     Int?      @map("parent_circle_id")
  knowledgeCount     Int       @default(0) @map("knowledge_count")
  genesisMode        String?   @map("genesis_mode") @db.VarChar(32) // canonical truth: 'BLANK' | 'SEEDED'
  
  membersCount       Int       @default(0) @map("members_count")
  postsCount         Int       @default(0) @map("posts_count")
  
  // Derived from on-chain flags bitfield
  kind               String    @default("main") @db.VarChar(16)    // "main" | "auxiliary"
  mode               String    @default("knowledge") @db.VarChar(16) // "knowledge" | "social"
  minCrystals        Int       @default(0) @map("min_crystals")     // bits 2-17 of flags
  lifecycleStatus    CircleLifecycleStatus @default(Active) @map("lifecycle_status")
  archivedAt         DateTime? @map("archived_at")
  archivedByPubkey   String?   @map("archived_by_pubkey") @db.VarChar(44)
  archiveReason      String?   @map("archive_reason")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  creator            User      @relation("CircleCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  parentCircle       Circle?   @relation("CircleHierarchy", fields: [parentCircleId], references: [id], onDelete: SetNull)
  childCircles       Circle[]  @relation("CircleHierarchy")
  members            CircleMember[]
  joinRequests       CircleJoinRequest[]
  invites            CircleInvite[]
  membershipEvents   CircleMembershipEvent[]
  posts              Post[]
  knowledge          Knowledge[]  @relation("CircleKnowledge")
  crystalEntitlements CrystalEntitlement[]
  crystalAssets      CrystalAsset[]
  crystalReceipts    CrystalReceipt[]
  knowledgeFrom      Knowledge[]  @relation("KnowledgeSource")
  seededSourceNodes  SeededSourceNode[]
  sourceMaterials    SourceMaterial[]
  agents             Agent[]
  agentPolicy        CircleAgentPolicy?
  acceptedDraftCandidates DraftCandidateAcceptance[]
  draftCandidateGenerationAttempts DraftCandidateGenerationAttempt[]
  
  @@index([creatorId])
  @@index([circleType])
  @@index([lifecycleStatus])
  @@index([level])
  @@index([parentCircleId])
  @@index([createdAt(sort: Desc)])
  @@index([membersCount(sort: Desc)])
  @@index([onChainAddress])
  @@map("circles")
}

enum CircleLifecycleStatus {
  Active
  Archived
}

model SeededSourceNode {
  id          Int      @id @default(autoincrement())
  circleId    Int      @map("circle_id")
  parentId    Int?     @map("parent_id")
  nodeType    String   @map("node_type") @db.VarChar(16) // "directory" | "file"
  name        String   @db.VarChar(255)
  path        String   @db.VarChar(1024)
  depth       Int
  sortOrder   Int      @default(0) @map("sort_order")
  mimeType    String?  @map("mime_type") @db.VarChar(255)
  contentText String?  @map("content_text")
  contentLocator String? @map("content_locator")
  contentHash String?  @map("content_hash") @db.Char(64)
  byteSize    Int      @default(0) @map("byte_size")
  lineCount   Int?     @map("line_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  circle      Circle            @relation(fields: [circleId], references: [id], onDelete: Cascade)
  parent      SeededSourceNode? @relation("SeededSourceNodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    SeededSourceNode[] @relation("SeededSourceNodeTree")

  @@unique([circleId, path])
  @@index([circleId, parentId, sortOrder])
  @@map("seeded_source_nodes")
}

model SourceMaterial {
  id                 Int      @id @default(autoincrement())
  circleId           Int      @map("circle_id")
  uploadedByUserId   Int      @map("uploaded_by_user_id")
  draftPostId        Int?     @map("draft_post_id")
  discussionThreadId String?  @map("discussion_thread_id") @db.VarChar(64)
  seededSourceNodeId Int?     @map("seeded_source_node_id")
  name               String   @db.VarChar(255)
  mimeType           String?  @map("mime_type") @db.VarChar(255)
  byteSize           Int      @default(0) @map("byte_size")
  extractionStatus   String   @default("ready") @map("extraction_status") @db.VarChar(32)
  rawText            String?  @map("raw_text")
  rawTextLocator     String?  @map("raw_text_locator")
  contentDigest      String   @map("content_digest") @db.Char(64)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  circle             Circle                @relation(fields: [circleId], references: [id], onDelete: Cascade)
  chunks             SourceMaterialChunk[]

  @@index([circleId, createdAt(sort: Desc)])
  @@index([draftPostId, createdAt(sort: Desc)])
  @@index([discussionThreadId, createdAt(sort: Desc)])
  @@index([seededSourceNodeId, createdAt(sort: Desc)])
  @@map("source_materials")
}

model SourceMaterialChunk {
  id               Int      @id @default(autoincrement())
  sourceMaterialId Int      @map("source_material_id")
  chunkIndex       Int      @map("chunk_index")
  locatorType      String   @map("locator_type") @db.VarChar(32)
  locatorRef       String   @map("locator_ref") @db.VarChar(128)
  text             String
  textLocator      String?  @map("text_locator")
  textDigest       String   @map("text_digest") @db.Char(64)
  createdAt        DateTime @default(now()) @map("created_at")

  sourceMaterial   SourceMaterial @relation(fields: [sourceMaterialId], references: [id], onDelete: Cascade)

  @@unique([sourceMaterialId, chunkIndex])
  @@index([sourceMaterialId, chunkIndex])
  @@map("source_material_chunks")
}

model Agent {
  id               Int      @id @default(autoincrement())
  circleId         Int      @map("circle_id")
  agentPubkey      String   @unique @map("agent_pubkey") @db.VarChar(44)
  handle           String   @db.VarChar(64)
  displayName      String?  @map("display_name") @db.VarChar(128)
  description      String?
  ownerUserId      Int?     @map("owner_user_id")
  createdByUserId  Int      @map("created_by_user_id")
  status           String   @default("active") @db.VarChar(16)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  circle           Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  owner            User?    @relation("AgentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdBy        User     @relation("AgentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([circleId, handle])
  @@index([circleId, createdAt(sort: Desc)])
  @@index([ownerUserId, createdAt(sort: Desc)])
  @@index([createdByUserId, createdAt(sort: Desc)])
  @@map("agents")
}

model CircleAgentPolicy {
  circleId         Int      @id @map("circle_id")
  triggerScope     String   @default("draft_only") @map("trigger_scope") @db.VarChar(32)
  costDiscountBps  Int      @default(0) @map("cost_discount_bps")
  reviewMode       String   @default("owner_review") @map("review_mode") @db.VarChar(32)
  updatedByUserId  Int?     @map("updated_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  circle           Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  updatedBy        User?    @relation("AgentPolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedByUserId, updatedAt(sort: Desc)])
  @@map("circle_agent_policies")
}

enum CircleType {
  Open
  Closed
  Secret
}

enum JoinRequirement {
  Free
  ApprovalRequired
  TokenGated
  InviteOnly
}

enum CircleJoinRequestStatus {
  Pending
  Approved
  Rejected
  Cancelled
  Expired
}

enum CircleInviteStatus {
  Active
  Accepted
  Revoked
  Expired
}

enum CircleMembershipEventType {
  JoinRequested
  JoinApproved
  JoinRejected
  Joined
  Left
  Banned
  Unbanned
  RoleChanged
  IdentityChanged
  InviteCreated
  InviteAccepted
}

model CircleMember {
  id                 Int       @id @default(autoincrement())
  circleId           Int       @map("circle_id")
  userId             Int       @map("user_id")
  
  role               MemberRole @default(Member)
  status             MemberStatus @default(Active)
  identityLevel      IdentityLevel @default(Visitor) @map("identity_level")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  joinedAt           DateTime  @default(now()) @map("joined_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  circle             Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
  @@index([status])
  @@index([role])
  @@index([identityLevel])
  @@map("circle_members")
}

model CircleJoinRequest {
  id                 Int       @id @default(autoincrement())
  circleId           Int       @map("circle_id")
  userId             Int       @map("user_id")
  status             CircleJoinRequestStatus @default(Pending)
  requestMessage     String?   @map("request_message")
  decisionReason     String?   @map("decision_reason")
  reviewedById       Int?      @map("reviewed_by_id")
  reviewedAt         DateTime? @map("reviewed_at")
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  circle             Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user               User      @relation("CircleJoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer           User?     @relation("CircleJoinRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  membershipEvents   CircleMembershipEvent[]

  @@index([circleId, status, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([reviewedById, reviewedAt(sort: Desc)])
  @@map("circle_join_requests")
}

model CircleInvite {
  id                 Int       @id @default(autoincrement())
  circleId           Int       @map("circle_id")
  inviterId          Int       @map("inviter_id")
  inviteeUserId      Int?      @map("invitee_user_id")
  inviteeHandle      String?   @map("invitee_handle") @db.VarChar(64)
  code               String    @unique @db.VarChar(128)
  status             CircleInviteStatus @default(Active)
  note               String?
  acceptedById       Int?      @map("accepted_by_id")
  acceptedAt         DateTime? @map("accepted_at")
  expiresAt          DateTime? @map("expires_at")
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  circle             Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inviter            User      @relation("CircleInviteSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee            User?     @relation("CircleInviteTarget", fields: [inviteeUserId], references: [id], onDelete: SetNull)
  acceptedBy         User?     @relation("CircleInviteAcceptor", fields: [acceptedById], references: [id], onDelete: SetNull)
  membershipEvents   CircleMembershipEvent[]

  @@index([circleId, status, createdAt(sort: Desc)])
  @@index([inviterId, createdAt(sort: Desc)])
  @@index([inviteeUserId, status, createdAt(sort: Desc)])
  @@index([inviteeHandle, status, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("circle_invites")
}

model CircleMembershipEvent {
  id                 BigInt    @id @default(autoincrement())
  circleId           Int       @map("circle_id")
  userId             Int       @map("user_id")
  actorUserId        Int?      @map("actor_user_id")
  eventType          CircleMembershipEventType @map("event_type")
  roleBefore         MemberRole? @map("role_before")
  roleAfter          MemberRole? @map("role_after")
  statusBefore       MemberStatus? @map("status_before")
  statusAfter        MemberStatus? @map("status_after")
  joinRequestId      Int?      @map("join_request_id")
  inviteId           Int?      @map("invite_id")
  reason             String?
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at")

  circle             Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user               User      @relation("CircleMembershipEventUser", fields: [userId], references: [id], onDelete: Cascade)
  actor              User?     @relation("CircleMembershipEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  joinRequest        CircleJoinRequest? @relation(fields: [joinRequestId], references: [id], onDelete: SetNull)
  invite             CircleInvite? @relation(fields: [inviteId], references: [id], onDelete: SetNull)

  @@index([circleId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([eventType, createdAt(sort: Desc)])
  @@map("circle_membership_events")
}

enum IdentityLevel {
  Visitor
  Initiate
  Member
  Elder
}

enum MemberRole {
  Owner
  Admin
  Moderator
  Member
}

enum MemberStatus {
  Active
  Banned
  Left
}

model Follow {
  id                 Int       @id @default(autoincrement())
  followerId         Int       @map("follower_id")
  followingId        Int       @map("following_id")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  // Relations
  follower           User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following          User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt(sort: Desc)])
  @@map("follows")
}

model Like {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  postId             Int       @map("post_id")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  // Relations
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post               Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@index([createdAt(sort: Desc)])
  @@map("likes")
}

model Conversation {
  id                 Int       @id @default(autoincrement())
  conversationId     String    @unique @map("conversation_id") @db.VarChar(44) // on-chain pubkey
  conversationType   ConversationType @default(Direct) @map("conversation_type")
  
  creatorId          Int       @map("creator_id")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  creator            User      @relation("ConversationCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  participants       ConversationParticipant[]
  messages           Message[]
  
  @@index([creatorId])
  @@index([conversationType])
  @@index([createdAt(sort: Desc)])
  @@map("conversations")
}

enum ConversationType {
  Direct
  Group
  Channel
}

model ConversationParticipant {
  id                 Int       @id @default(autoincrement())
  conversationId     Int       @map("conversation_id")
