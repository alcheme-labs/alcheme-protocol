model IndexerFailedSlot {
  id           BigInt   @id @default(autoincrement())
  programId    String   @map("program_id") @db.VarChar(44)
  slot         BigInt
  eventSource  String   @default("local") @map("event_source") @db.VarChar(16)
  firstFailedAt DateTime @default(now()) @map("first_failed_at")
  lastFailedAt DateTime @default(now()) @map("last_failed_at")
  lastReplayAt DateTime? @map("last_replay_at")
  failedCount  Int      @default(1) @map("failed_count")
  lastError    String?  @map("last_error")
  resolved     Boolean  @default(false)
  resolvedAt   DateTime? @map("resolved_at")
