}

model CrystalReceipt {
  id                   Int       @id @default(autoincrement())
  entitlementId        Int       @unique @map("entitlement_id")
  knowledgeRowId       Int       @map("knowledge_row_id")
  knowledgePublicId    String    @map("knowledge_public_id") @db.VarChar(64)
  circleId             Int       @map("circle_id")
  ownerPubkey          String    @map("owner_pubkey") @db.VarChar(44)
  ownerUserId          Int?      @map("owner_user_id")
  contributionRole     String    @map("contribution_role") @db.VarChar(32)
  contributionWeightBps Int      @map("contribution_weight_bps")
  receiptAssetAddress  String?   @map("receipt_asset_address") @db.VarChar(128)
  assetStandard        String    @map("asset_standard") @db.VarChar(64)
  transferMode         String    @default("non_transferable") @map("transfer_mode") @db.VarChar(32)
  mintStatus           String    @default("pending") @map("mint_status") @db.VarChar(24)
  metadataUri          String?   @map("metadata_uri")
  proofPackageHash     String    @map("proof_package_hash") @db.Char(64)
  sourceAnchorId       String    @map("source_anchor_id") @db.Char(64)
  contributorsRoot     String    @map("contributors_root") @db.Char(64)
  contributorsCount    Int       @map("contributors_count")
  mintedAt             DateTime? @map("minted_at")
  lastError            String?   @map("last_error")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  entitlement          CrystalEntitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  knowledge            Knowledge          @relation(fields: [knowledgeRowId], references: [id], onDelete: Cascade)
  circle               Circle             @relation(fields: [circleId], references: [id], onDelete: Cascade)
  ownerUser            User?              @relation("CrystalReceiptOwnerUser", fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Safe under the current proof invariant: one pubkey does not persist as both
  // Author and Discussant for the same crystallized knowledge item.
  @@unique([knowledgeRowId, ownerPubkey])
  @@index([ownerPubkey, mintStatus, circleId])
  @@index([ownerUserId, mintStatus])
  @@index([circleId, mintStatus])
  @@map("crystal_receipts")
}

