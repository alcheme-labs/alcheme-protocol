  @@unique([programId, slot])
  @@index([programId, resolved, slot])
  @@index([resolved, lastFailedAt])
  @@map("indexer_failed_slots")
}

model Knowledge {
  id                 Int       @id @default(autoincrement())
  knowledgeId        String    @unique @map("knowledge_id") @db.VarChar(64)
  circleId           Int       @map("circle_id")
  
  title              String    @db.VarChar(256)
  description        String?
  ipfsCid            String?   @map("ipfs_cid") @db.VarChar(128)
  contentHash        String?   @map("content_hash") @db.VarChar(64)  // hex-encoded SHA-256
  
  authorId           Int       @map("author_id")
  qualityScore       Decimal   @default(0) @map("quality_score") @db.Decimal(10, 4)
  heatScore          Decimal   @default(0) @map("heat_score") @db.Decimal(10, 4)
  citationCount      Int       @default(0) @map("citation_count")
  viewCount          Int       @default(0) @map("view_count")
  
  sourceCircleId     Int?      @map("source_circle_id")
  sourceContentId    String?   @map("source_content_id") @db.VarChar(128)
  
  // Derived from on-chain flags bitfield + Merkle contributor tracking
  version            Int       @default(1)                         // bits 0-15 of flags
  contributorsRoot   String?   @map("contributors_root") @db.VarChar(64)  // hex-encoded Merkle root
  contributorsCount  Int       @default(0) @map("contributors_count")
  
  onChainAddress     String    @unique @map("on_chain_address") @db.VarChar(44)
  lastSyncedSlot     BigInt    @map("last_synced_slot")
  
  // Frozen crystal visual parameters (computed at crystallization, immutable)
  // JSON: { "seed": "0x...", "hue": 200, "facets": 8 }
  crystalParams      Json?     @map("crystal_params") @db.JsonB
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  circle             Circle    @relation("CircleKnowledge", fields: [circleId], references: [id], onDelete: Cascade)
  author             User      @relation("AuthoredKnowledge", fields: [authorId], references: [id], onDelete: Cascade)
  sourceCircle       Circle?   @relation("KnowledgeSource", fields: [sourceCircleId], references: [id], onDelete: SetNull)
  contributions      KnowledgeContribution[]
  binding            KnowledgeBinding?
  crystalEntitlements CrystalEntitlement[]
  crystalAsset       CrystalAsset?
  crystalReceipts    CrystalReceipt[]
  
  @@index([circleId])
  @@index([authorId])
  @@index([qualityScore(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("knowledge")
}

model KnowledgeBinding {
  knowledgeId        String   @id @map("knowledge_id") @db.VarChar(64)
  sourceAnchorId     String   @map("source_anchor_id") @db.Char(64)
  proofPackageHash   String   @map("proof_package_hash") @db.Char(64)
  contributorsRoot   String   @map("contributors_root") @db.Char(64)
  contributorsCount  Int      @map("contributors_count")
  bindingVersion     Int      @map("binding_version")
  generatedAt        DateTime @map("generated_at")
  boundAt            DateTime @map("bound_at")
  boundBy            String   @map("bound_by") @db.VarChar(44)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  knowledge          Knowledge @relation(fields: [knowledgeId], references: [knowledgeId], onDelete: Cascade)

  @@index([proofPackageHash])
  @@index([boundAt(sort: Desc)])
  @@map("knowledge_binding")
}

model KnowledgeReference {
  sourceKnowledgeId  String   @map("source_knowledge_id") @db.VarChar(64)
  targetKnowledgeId  String   @map("target_knowledge_id") @db.VarChar(64)
  referenceType      String   @default("citation") @map("reference_type") @db.VarChar(32)
  createdAt          DateTime @default(now()) @map("created_at")

  @@id([sourceKnowledgeId, targetKnowledgeId])
  @@index([targetKnowledgeId])
  @@map("knowledge_references")
}

model KnowledgeVersionEvent {
  id                   BigInt   @id @default(autoincrement())
  knowledgeId          String   @map("knowledge_id") @db.VarChar(64)
  eventType            String   @map("event_type") @db.VarChar(32)
