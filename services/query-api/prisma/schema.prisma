  signedMessage      String    @map("signed_message")
  signatureVerified  Boolean   @default(false) @map("signature_verified")
  authMode           String    @default("wallet_per_message") @map("auth_mode") @db.VarChar(32)
  sessionId          String?   @map("session_id") @db.VarChar(64)
  relevanceScore     Decimal   @default(1) @map("relevance_score") @db.Decimal(4, 3)
  relevanceStatus    String    @default("ready") @map("relevance_status") @db.VarChar(16)
  semanticScore      Decimal?  @map("semantic_score") @db.Decimal(4, 3)
  embeddingScore     Decimal?  @map("embedding_score") @db.Decimal(4, 3)
  qualityScore       Decimal?  @map("quality_score") @db.Decimal(4, 3)
  spamScore          Decimal?  @map("spam_score") @db.Decimal(4, 3)
  decisionConfidence Decimal?  @map("decision_confidence") @db.Decimal(4, 3)
  relevanceMethod    String    @default("rule") @map("relevance_method") @db.VarChar(32)
  actualMode         String?   @map("actual_mode") @db.VarChar(32)
  analysisVersion    String?   @map("analysis_version") @db.VarChar(32)
  topicProfileVersion String?  @map("topic_profile_version") @db.VarChar(128)
  semanticFacets     Json      @default("[]") @map("semantic_facets")
  focusScore         Decimal?  @map("focus_score") @db.Decimal(4, 3)
  focusLabel         String?   @map("focus_label") @db.VarChar(16)
  isFeatured         Boolean   @default(false) @map("is_featured")
  featureReason      String?   @map("feature_reason") @db.VarChar(240)
  featuredAt         DateTime? @map("featured_at")
  analysisCompletedAt DateTime? @map("analysis_completed_at")
  analysisErrorCode  String?   @map("analysis_error_code") @db.VarChar(64)
  analysisErrorMessage String? @map("analysis_error_message")
  authorAnnotations  Json      @default("[]") @map("author_annotations")
  isEphemeral        Boolean   @default(false) @map("is_ephemeral")
  expiresAt          DateTime? @map("expires_at")
  clientTimestamp    DateTime  @map("client_timestamp")
  lamport            BigInt
  prevEnvelopeId     String?   @map("prev_envelope_id") @db.VarChar(96)
  deleted            Boolean   @default(false)
  tombstoneReason    String?   @map("tombstone_reason") @db.VarChar(64)
  tombstonedAt       DateTime? @map("tombstoned_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([roomKey, lamport(sort: Desc)])
  @@index([streamKey, lamport])
  @@index([circleId, lamport(sort: Desc)])
  @@index([senderPubkey, lamport(sort: Desc)])
  @@index([sessionId])
  @@index([relevanceScore])
  @@index([relevanceStatus])
  @@index([semanticScore])
  @@index([spamScore])
  @@index([circleId, isFeatured, featuredAt(sort: Desc)])
  @@index([circleId, isEphemeral, lamport(sort: Desc)])
  @@index([isEphemeral, expiresAt])
  @@index([circleId, messageKind, lamport(sort: Desc)])
  @@index([subjectType, subjectId, lamport(sort: Desc)])
  @@index([subjectType, subjectId, messageKind, lamport(sort: Desc)])
  @@index([circleId, subjectType, subjectId, lamport(sort: Desc)])
  @@map("circle_discussion_messages")
}

