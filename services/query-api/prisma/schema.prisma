  claimToken                 String?  @map("claim_token") @db.VarChar(64)
  claimedUntil               DateTime? @map("claimed_until")
  attemptCount               Int      @default(0) @map("attempt_count")
  sourceMessageIds           Json     @default("[]") @map("source_message_ids")
  sourceSemanticFacets       Json     @default("[]") @map("source_semantic_facets")
  sourceAuthorAnnotations    Json     @default("[]") @map("source_author_annotations")
  lastProposalId             String?  @map("last_proposal_id") @db.VarChar(128)
  summaryMethod              String?  @map("summary_method") @db.VarChar(32)
  draftGenerationMethod      String?  @map("draft_generation_method") @db.VarChar(32)
  draftGenerationError       String?  @map("draft_generation_error") @db.VarChar(128)
  draftGenerationDiagnostics Json?    @map("draft_generation_diagnostics")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @default(now()) @updatedAt @map("updated_at")

  circle                     Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  draftPost                  Post?    @relation(fields: [draftPostId], references: [id], onDelete: SetNull)
  attemptedBy                User?    @relation("DraftCandidateAttemptedBy", fields: [attemptedByUserId], references: [id], onDelete: SetNull)

  @@unique([circleId, candidateId, sourceMessagesDigest])
  @@index([circleId, status, updatedAt(sort: Desc)])
  @@index([draftPostId])
  @@index([attemptedByUserId, updatedAt(sort: Desc)])
  @@map("draft_candidate_generation_attempts")
}

// ==================== Tracker 服务写入的表 (只读) ====================

model AuthorityScore {
  id                 Int       @id @default(autoincrement())
  crystalId          String    @map("crystal_id") @db.VarChar(128)
  score              Decimal   @db.Decimal(18, 8)
  epoch              Int
  
  calculatedAt       DateTime  @default(now()) @map("calculated_at")
  
  @@unique([crystalId, epoch])
  @@index([crystalId])
  @@index([epoch])
  @@index([score(sort: Desc)])
  @@map("authority_scores")
}

model AntiGamingFlag {
  id                 Int       @id @default(autoincrement())
  userPubkey         String    @map("user_pubkey") @db.VarChar(44)
  flagType           String    @map("flag_type") @db.VarChar(64)
  details            Json?
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  @@index([userPubkey])
  @@index([flagType])
  @@index([createdAt(sort: Desc)])
  @@map("anti_gaming_flags")
}

model SettlementHistory {
  id                 Int       @id @default(autoincrement())
  crystalId          String    @map("crystal_id") @db.VarChar(128)
  contributorPubkey  String    @map("contributor_pubkey") @db.VarChar(44)
  contributionRole   String?   @map("contribution_role") @db.VarChar(32)
  contributionWeight Decimal?  @map("contribution_weight") @db.Decimal(10, 4)
  authorityScore     Decimal   @map("authority_score") @db.Decimal(18, 8)
  reputationDelta    Decimal   @map("reputation_delta") @db.Decimal(18, 8)
  txSignature        String?   @map("tx_signature") @db.VarChar(88)
  
  settledAt          DateTime  @default(now()) @map("settled_at")
  
  @@index([crystalId])
  @@index([contributorPubkey])
  @@index([settledAt(sort: Desc)])
  @@map("settlement_history")
}

// ==================== 通知聚合 ====================

model Notification {
  id                 Int       @id @default(autoincrement())
  userId             Int       @map("user_id")
  
  type               String    @db.VarChar(32) // 'like', 'comment', 'follow', 'mention', 'crystal', 'reputation'
  title              String    @db.VarChar(256)
  body               String?
  metadata           Json?     @db.JsonB
  
  sourceType         String?   @map("source_type") @db.VarChar(32) // 'post', 'user', 'circle', 'knowledge'
  sourceId           String?   @map("source_id") @db.VarChar(128)
  circleId           Int?      @map("circle_id")
  
  read               Boolean   @default(false)
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  // Relations
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@index([type])
  @@map("notifications")
}

// ==================== 图腾 (Totem) ====================

model UserTotem {
  userId          Int       @id @map("user_id")
  stage           String    @default("seed") @db.VarChar(16)
  crystalCount    Int       @default(0) @map("crystal_count")
  citationCount   Int       @default(0) @map("citation_count")
  circleCount     Int       @default(0) @map("circle_count")
  lastActiveAt    DateTime  @default(now()) @map("last_active_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_totem")
}

// ==================== 权限 & 关系 & 经济 (DbWriter 支撑) ====================

model AccessRule {
  id                 Int       @id @default(autoincrement())
  userPubkey         String    @map("user_pubkey") @db.VarChar(44)
  ruleId             String    @unique @map("rule_id") @db.VarChar(128)
  permission         String    @db.VarChar(64) // 'read', 'write', 'admin', 'moderate'
  accessLevel        String    @map("access_level") @db.VarChar(32) // 'circle', 'global'
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  @@index([userPubkey])
  @@index([permission])
  @@map("access_rules")
}

model Permission {
  id                 Int       @id @default(autoincrement())
  granterPubkey      String    @map("granter_pubkey") @db.VarChar(44)
  granteePubkey      String    @map("grantee_pubkey") @db.VarChar(44)
  permission         String    @db.VarChar(64)
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  @@unique([granterPubkey, granteePubkey, permission])
  @@index([granteePubkey])
  @@map("permissions")
}

model UserRelationship {
  id                 Int       @id @default(autoincrement())
  user1Pubkey        String    @map("user1_pubkey") @db.VarChar(44)
  user2Pubkey        String    @map("user2_pubkey") @db.VarChar(44)
  relationship       String    @db.VarChar(32) // 'friend', 'blocked', 'muted', 'trusted'
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")
  
  @@unique([user1Pubkey, user2Pubkey])
  @@index([user1Pubkey])
  @@index([user2Pubkey])
  @@map("user_relationships")
}

model TokenTransaction {
  id                 Int       @id @default(autoincrement())
  pubkey             String    @db.VarChar(44)
  amount             BigInt
  transactionType    String    @map("transaction_type") @db.VarChar(32) // 'mint', 'burn', 'transfer', 'reward'
  purpose            String    @db.VarChar(128)
  
  createdAt          DateTime  @default(now()) @map("created_at")
  
  @@index([pubkey])
  @@index([transactionType])
  @@index([createdAt(sort: Desc)])
  @@map("token_transactions")
}
