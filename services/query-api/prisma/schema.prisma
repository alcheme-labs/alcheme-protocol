  draftPostId          Int      @map("draft_post_id")
  proofPackageHash     String   @map("proof_package_hash") @db.Char(64)
  sourceAnchorId       String   @map("source_anchor_id") @db.VarChar(128)
  contributorsRoot     String   @map("contributors_root") @db.Char(64)
  contributorsCount    Int      @map("contributors_count")
  bindingVersion       Int      @default(2) @map("binding_version")
  canonicalProofPackage Json    @map("canonical_proof_package")
  generatedAt          DateTime @map("generated_at")
  generatedBy          String   @map("generated_by") @db.VarChar(64)
  createdAt            DateTime @default(now()) @map("created_at")

  issuances            DraftProofPackageIssuance[]

  @@unique([draftPostId, proofPackageHash])
  @@index([draftPostId, generatedAt(sort: Desc)])
  @@map("draft_proof_packages")
}

model DraftProofPackageIssuance {
  id             BigInt   @id @default(autoincrement())
  proofPackageId BigInt   @map("proof_package_id")
  issuerKeyId    String   @map("issuer_key_id") @db.VarChar(64)
  issuedSignature String  @map("issued_signature") @db.VarChar(512)
  issuedAt       DateTime @map("issued_at")
  createdAt      DateTime @default(now()) @map("created_at")

  proofPackage   DraftProofPackage @relation(fields: [proofPackageId], references: [id], onDelete: Cascade)

  @@index([proofPackageId, issuedAt(sort: Desc)])
  @@index([issuerKeyId, issuedAt(sort: Desc)])
  @@map("draft_proof_package_issuances")
}

model OffchainSyncWatermark {
  streamKey        String    @id @map("stream_key") @db.VarChar(64)
