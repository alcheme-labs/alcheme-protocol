DATABASE_URL=postgresql://alcheme:password@localhost:5432/alcheme_indexer
REDIS_URL=redis://localhost:6379
PORT=4000
NODE_ENV=development
SOLANA_RPC_URL=http://127.0.0.1:8899
CONTENT_PROGRAM_ID=

# AI provider / model config
AI_MODE=builtin
AI_BUILTIN_TEXT_API=chat_completions
NEW_API_URL=https://your-openai-compatible-endpoint.example/v1
NEW_API_KEY=sk-dev-change-me
SCORING_MODEL=qwen2.5:7b
GHOST_DRAFT_MODEL=llama3.1:8b
DISCUSSION_SUMMARY_MODEL=qwen2.5:7b
DISCUSSION_TRIGGER_MODEL=qwen2.5:7b
EMBEDDING_MODEL=BAAI/bge-m3

# draft proof issuance signer (ed25519)
# issuer key id must match the public key derived from issuer secret
# secret supports: JSON byte array (64/32), hex, or base58
DRAFT_PROOF_ISSUER_KEY_ID=
DRAFT_PROOF_ISSUER_SECRET=
MEMBERSHIP_BRIDGE_ISSUER_KEY_ID=
MEMBERSHIP_BRIDGE_ISSUER_SECRET=

# API rate limit
# Global bucket (most /api/v1 routes)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
# Dedicated high-frequency bucket for discussion message polling
DISCUSSION_READ_RATE_LIMIT_MAX=1200

# identity policy
IDENTITY_INITIATE_MESSAGES=3
IDENTITY_MEMBER_CITATIONS=2
IDENTITY_ELDER_PERCENTILE=10
IDENTITY_INACTIVITY_DAYS=30
IDENTITY_NOTIFICATION_MODE=all
IDENTITY_POLICY_BY_CIRCLE_JSON={}

# /sync/status alert thresholds
INDEXER_SLOT_LAG_WARNING=2000
INDEXER_SLOT_LAG_CRITICAL=10000
INDEXER_FAILED_SLOT_WARNING_COUNT=1
INDEXER_FAILED_SLOT_CRITICAL_AGE_SEC=300
PENDING_GHOST_SETTINGS_WARNING_COUNT=10
PENDING_GHOST_SETTINGS_CRITICAL_AGE_SEC=900

# pending circle ghost settings reconciler
PENDING_GHOST_SETTINGS_RECONCILER_ENABLED=true
PENDING_GHOST_SETTINGS_RECONCILE_INTERVAL_MS=5000
PENDING_GHOST_SETTINGS_RECONCILE_BATCH_SIZE=100
PENDING_GHOST_SETTINGS_TTL_SEC=21600
PENDING_GHOST_SETTINGS_MAX_PER_ACTOR=20

# ghost settings write auth hardening
GHOST_SETTINGS_SIGNATURE_WINDOW_MS=300000
GHOST_SETTINGS_NONCE_TTL_SEC=600
GHOST_SETTINGS_PENDING_TX_MAX_AGE_SEC=1800
GHOST_SETTINGS_RPC_TIMEOUT_MS=5000
CIRCLES_PROGRAM_ID=
