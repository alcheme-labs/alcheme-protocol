DATABASE_URL=postgresql://alcheme:password@localhost:5432/alcheme_indexer
REDIS_URL=redis://localhost:6379
PORT=4000
NODE_ENV=development
SOLANA_RPC_URL=http://127.0.0.1:8899
CONTENT_PROGRAM_ID=

# AI provider / model config
AI_MODE=builtin
AI_BUILTIN_TEXT_API=chat_completions
NEW_API_URL=https://your-openai-compatible-endpoint.example/v1
NEW_API_KEY=sk-dev-change-me
NEW_API_TIMEOUT_MS=15000
AI_GATEWAY_TIMEOUT_MS=15000
SCORING_MODEL=qwen2.5:7b
GHOST_DRAFT_MODEL=llama3.1:8b
DISCUSSION_INITIAL_DRAFT_MODEL=llama3.1:8b
DISCUSSION_SUMMARY_MODEL=qwen2.5:7b
DISCUSSION_TRIGGER_MODEL=qwen2.5:7b
EMBEDDING_MODEL=BAAI/bge-m3

# draft proof issuance signer (ed25519)
# issuer key id must match the public key derived from issuer secret
# secret supports: JSON byte array (64/32), hex, or base58
DRAFT_PROOF_ISSUER_KEY_ID=
DRAFT_PROOF_ISSUER_SECRET=
# trusted membership attestor for admission grants
# this key must be registered in the on-chain membership attestor registry
# issuer key id must match the public key derived from issuer secret
# secret supports: JSON byte array (64/32), hex, or base58
MEMBERSHIP_BRIDGE_ISSUER_KEY_ID=
MEMBERSHIP_BRIDGE_ISSUER_SECRET=

# API rate limit
# Global bucket (most /api/v1 routes)
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=100
# Dedicated high-frequency bucket for discussion message polling
DISCUSSION_READ_RATE_LIMIT_MAX=1200

# identity policy
IDENTITY_INITIATE_MESSAGES=3
IDENTITY_MEMBER_CITATIONS=2
IDENTITY_ELDER_PERCENTILE=10
IDENTITY_INACTIVITY_DAYS=30
IDENTITY_NOTIFICATION_MODE=all
IDENTITY_POLICY_BY_CIRCLE_JSON={}

# /sync/status alert thresholds
INDEXER_SLOT_LAG_WARNING=2000
INDEXER_SLOT_LAG_CRITICAL=10000
INDEXER_FAILED_SLOT_WARNING_COUNT=1
INDEXER_FAILED_SLOT_CRITICAL_AGE_SEC=300
PENDING_GHOST_SETTINGS_WARNING_COUNT=10
PENDING_GHOST_SETTINGS_CRITICAL_AGE_SEC=900

# pending circle ghost settings reconciler
PENDING_GHOST_SETTINGS_RECONCILER_ENABLED=true
PENDING_GHOST_SETTINGS_RECONCILE_INTERVAL_MS=5000
PENDING_GHOST_SETTINGS_RECONCILE_BATCH_SIZE=100
PENDING_GHOST_SETTINGS_TTL_SEC=21600
PENDING_GHOST_SETTINGS_MAX_PER_ACTOR=20

# ghost settings write auth hardening
GHOST_SETTINGS_SIGNATURE_WINDOW_MS=300000
GHOST_SETTINGS_NONCE_TTL_SEC=600
GHOST_SETTINGS_PENDING_TX_MAX_AGE_SEC=1800
GHOST_SETTINGS_RPC_TIMEOUT_MS=5000

# draft lifecycle anchor verification
# Increase attempts on devnet/demo when wallet-submitted lifecycle txs are not
# immediately visible to the API node.
DRAFT_LIFECYCLE_ANCHOR_LOOKUP_ATTEMPTS=30
DRAFT_LIFECYCLE_ANCHOR_LOOKUP_DELAY_MS=1000
DRAFT_LIFECYCLE_ANCHOR_RPC_TIMEOUT_MS=5000

# Anchor writers for source-evidence and collaborative-edit memo anchors.
# In production/demo these default closed unless explicitly enabled.
DRAFT_ANCHOR_ENABLED=true
DRAFT_ANCHOR_WRITER_ENABLED=true
DRAFT_ANCHOR_RPC_URL=
COLLAB_EDIT_ANCHOR_ENABLED=true
COLLAB_EDIT_ANCHOR_WRITER_ENABLED=true
COLLAB_EDIT_ANCHOR_RPC_URL=
ANCHOR_SIGNER_MODE=external
ANCHOR_SIGNER_URL=http://127.0.0.1:8787/sign
ANCHOR_SIGNER_AUTH_TOKEN=CHANGE_ME_ANCHOR_SIGNER_TOKEN
ANCHOR_SIGNER_TIMEOUT_MS=10000
CIRCLES_PROGRAM_ID=

# External app sandbox/dev onboarding.
# Server/operator secret for POST /api/v1/external-apps in local/demo onboarding.
# Do not expose this to browser SDKs or external games. Mainnet production
# approval should use the app registry/governance path, not this dev shortcut.
EXTERNAL_APP_ADMIN_TOKEN=CHANGE_ME_EXTERNAL_APP_ADMIN_TOKEN

# Voice provider.
# disabled: chat/room APIs keep working, but voice session/token APIs reject calls.
# livekit: query-api mints LiveKit access tokens and can verify provider health.
VOICE_PROVIDER=disabled
# WebSocket URL returned to browsers and SDK clients for LiveKit connection.
VOICE_PUBLIC_URL=ws://localhost:7880
# Server-side URL used by query-api to call LiveKit health/room APIs. In Docker
# this is usually http://livekit:7880; local host runs can use 127.0.0.1.
LIVEKIT_SERVER_URL=http://127.0.0.1:7880
# Server-side LiveKit credentials. devkey/secret are only for local LiveKit dev mode.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# false keeps local chat testing usable when LiveKit is down; true rejects voice
# session/token calls if provider health cannot be confirmed.
VOICE_REQUIRE_PROVIDER_HEALTH=false
# Health check timeout for LiveKit provider checks.
VOICE_PROVIDER_HEALTH_TIMEOUT_MS=1500
