        "ai": "^6.0.90",
        "apollo-server-express": "^3.13.0",
        "bs58": "^6.0.0",
        "cors": "^2.8.5",
        "dataloader": "^2.2.2",
        "dotenv": "^16.4.0",
        "express": "^4.19.0",
        "express-rate-limit": "^7.4.0",
        "graphql": "^16.8.0",
        "helmet": "^7.1.0",
