# Rust 索引器环境变量
INDEXER_EVENT_SOURCE=yellowstone
LOCAL_LISTENER_MODE=program_cursor
LOCAL_BACKFILL_SIGNATURE_LIMIT=32
LOCAL_RPC_REQUEST_TIMEOUT_MS=12000
RPC_ENDPOINT=https://your-yellowstone-grpc-endpoint.com
YELLOWSTONE_ENDPOINT=https://your-yellowstone-grpc-endpoint.com
YELLOWSTONE_TOKEN=CHANGE_ME
EVENT_EMITTER_PROGRAM_ID=Your_Event_Emitter_Program_ID_Here

# 数据库配置
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# API配置
PORT=4000
INDEXER_ID=local-indexer-1
INDEXER_READ_COMMITMENT=confirmed
INDEXER_STALE_AFTER_MS=120000
CONSISTENCY_HEADER_TTL_MS=1000

# 日志级别
RUST_LOG=info

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# P3 服务配置
NEW_API_URL=https://your-openai-compatible-endpoint.example/v1
NEW_API_KEY=CHANGE_ME_AI_API_KEY
COLLAB_MODE=builtin
AI_MODE=builtin
AI_BUILTIN_TEXT_API=chat_completions
SCORING_MODEL=qwen2.5:7b
GHOST_DRAFT_MODEL=llama3.1:8b
DISCUSSION_SUMMARY_MODEL=qwen2.5:7b
DISCUSSION_TRIGGER_MODEL=qwen2.5:7b
EMBEDDING_MODEL=BAAI/bge-m3
