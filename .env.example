# Rust 索引器环境变量
INDEXER_EVENT_SOURCE=yellowstone
LOCAL_LISTENER_MODE=program_cursor
LOCAL_BACKFILL_SIGNATURE_LIMIT=32
LOCAL_RPC_REQUEST_TIMEOUT_MS=12000
RPC_ENDPOINT=https://your-yellowstone-grpc-endpoint.com
YELLOWSTONE_ENDPOINT=https://your-yellowstone-grpc-endpoint.com
YELLOWSTONE_TOKEN=CHANGE_ME
EVENT_EMITTER_PROGRAM_ID=Your_Event_Emitter_Program_ID_Here
EXTERNAL_APP_REGISTRY_PROGRAM_ID=Your_External_App_Registry_Program_ID_Here
# ExternalApp Registry V2 chain anchoring:
# disabled: do not submit chain registry txs.
# optional: submit when all config is present, otherwise keep V1 runtime usable.
# required: production trust requires chain registration and receipt anchor.
EXTERNAL_APP_REGISTRY_MODE=disabled
# Local/dev only. Production must use a signer sidecar, multisig, or hardened
# authority service instead of loading a governance authority key directly.
EXTERNAL_APP_REGISTRY_AUTHORITY_KEYPAIR_PATH=
EXTERNAL_APP_REGISTRY_AUTHORITY_SIGNER_URL=
EXTERNAL_APP_REGISTRY_AUTHORITY_SIGNER_TOKEN=
EXTERNAL_APP_REGISTRY_IDL_PATH=
# ExternalApp V3B economics program. Keep disabled unless local/devnet custody
# smoke tests explicitly opt in; production asset allowlist starts empty.
EXTERNAL_APP_ECONOMICS_PROGRAM_ID=Your_External_App_Economics_Program_ID_Here
EXTERNAL_APP_ECONOMICS_MODE=disabled
EXTERNAL_APP_ECONOMICS_AUTHORITY_KEYPAIR_PATH=
EXTERNAL_APP_ECONOMICS_AUTHORITY_SIGNER_URL=
EXTERNAL_APP_ECONOMICS_AUTHORITY_SIGNER_TOKEN=
EXTERNAL_APP_ECONOMICS_IDL_PATH=
# Verifies developer/participant risk-disclaimer chain receipts before Query API
# records them. Defaults to required in NODE_ENV=production and disabled outside
# production unless explicitly set. Requires EXTERNAL_APP_ECONOMICS_PROGRAM_ID
# and SOLANA_RPC_URL/RPC_URL/NEXT_PUBLIC_SOLANA_RPC_URL when enabled.
EXTERNAL_APP_RISK_RECEIPT_VERIFICATION_MODE=disabled

# ExternalApp core review council role binding bootstrap.
# These must point to an existing auxiliary + governance + Secret circle and an
# active GovernancePolicy/GovernancePolicyVersion scoped to that circle. The
# bootstrap script refuses to create an ordinary content circle as a core council.
EXTERNAL_APP_REVIEW_PRIMARY_CIRCLE_ID=
EXTERNAL_APP_REVIEW_PRIMARY_POLICY_ID=
EXTERNAL_APP_REVIEW_PRIMARY_POLICY_VERSION_ID=
EXTERNAL_APP_REVIEW_PRIMARY_ENVIRONMENT=production
EXTERNAL_APP_REVIEW_PRIMARY_CREATED_BY_PUBKEY=

# ExternalApp V3 settlement asset controls.
# Production must start disabled with an empty allowlist. Local/devnet may use
# test_mint mode for smoke tests only.
EXTERNAL_APP_SETTLEMENT_ASSET_MODE=disabled
EXTERNAL_APP_SETTLEMENT_TEST_MINT=
EXTERNAL_APP_SETTLEMENT_TEST_MINT_AUTHORITY=

# 数据库配置
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# API配置
PORT=4000
INDEXER_ID=local-indexer-1
INDEXER_READ_COMMITMENT=confirmed
INDEXER_STALE_AFTER_MS=120000
CONSISTENCY_HEADER_TTL_MS=1000

# 日志级别
RUST_LOG=info

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# P3 服务配置
NEW_API_URL=https://your-openai-compatible-endpoint.example/v1
NEW_API_KEY=CHANGE_ME_AI_API_KEY
NEW_API_TIMEOUT_MS=15000
AI_GATEWAY_TIMEOUT_MS=15000
COLLAB_MODE=builtin
AI_MODE=builtin
AI_BUILTIN_TEXT_API=chat_completions
SCORING_MODEL=qwen2.5:7b
GHOST_DRAFT_MODEL=llama3.1:8b
DISCUSSION_INITIAL_DRAFT_MODEL=llama3.1:8b
DISCUSSION_SUMMARY_MODEL=qwen2.5:7b
DISCUSSION_TRIGGER_MODEL=qwen2.5:7b
EMBEDDING_MODEL=BAAI/bge-m3

# Draft lifecycle on-chain anchor verification
# Demo/devnet should use a longer lookup window because wallet-submitted txs may not be
# immediately visible to the API node.
DRAFT_LIFECYCLE_ANCHOR_LOOKUP_ATTEMPTS=30
DRAFT_LIFECYCLE_ANCHOR_LOOKUP_DELAY_MS=1000
DRAFT_LIFECYCLE_ANCHOR_RPC_TIMEOUT_MS=5000

# Anchor writers for discussion source evidence and collaborative edit evidence.
# Production/demo must enable these explicitly and provide either an external signer
# or a mounted local keypair with SOL for memo transactions.
DRAFT_ANCHOR_ENABLED=true
DRAFT_ANCHOR_WRITER_ENABLED=true
DRAFT_ANCHOR_RPC_URL=
COLLAB_EDIT_ANCHOR_ENABLED=true
COLLAB_EDIT_ANCHOR_WRITER_ENABLED=true
COLLAB_EDIT_ANCHOR_RPC_URL=
ANCHOR_SIGNER_MODE=external
# Docker containers cannot reach a host signer through 127.0.0.1. Use a URL
# reachable from the query-api container, such as http://host.docker.internal:8787/sign
# on Docker Desktop or http://anchor-signer:8787/sign when running a signer service.
ANCHOR_SIGNER_URL=
ANCHOR_SIGNER_AUTH_TOKEN=CHANGE_ME_ANCHOR_SIGNER_TOKEN
ANCHOR_SIGNER_TIMEOUT_MS=10000
