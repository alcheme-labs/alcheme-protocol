FROM node:20-alpine AS build-base

RUN apk add --no-cache python3 make g++ eudev-dev

WORKDIR /app
FROM build-base AS builder

WORKDIR /app/sdk
COPY sdk/package*.json ./
RUN npm ci
COPY sdk ./
RUN npm run build

WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm ci
COPY frontend ./

ARG NEXT_PUBLIC_GRAPHQL_URL
ARG NEXT_PUBLIC_QUERY_API_BASE_URL
ARG NEXT_PUBLIC_SIDECAR_BASE_URL
ARG NEXT_PUBLIC_COLLAB_WS_URL
ARG NEXT_PUBLIC_SOLANA_RPC_URL
ARG NEXT_PUBLIC_IDENTITY_REGISTRY_NAME
ARG NEXT_PUBLIC_IDENTITY_PROGRAM_ID
ARG NEXT_PUBLIC_CONTENT_PROGRAM_ID
ARG NEXT_PUBLIC_ACCESS_PROGRAM_ID
ARG NEXT_PUBLIC_EVENT_PROGRAM_ID
ARG NEXT_PUBLIC_FACTORY_PROGRAM_ID
ARG NEXT_PUBLIC_MESSAGING_PROGRAM_ID
ARG NEXT_PUBLIC_CIRCLES_PROGRAM_ID
ARG NEXT_PUBLIC_CONTRIBUTION_ENGINE_PROGRAM_ID
ARG NEXT_PUBLIC_AUTH_SESSION_REQUIRE_SIGNATURE
ARG NEXT_PUBLIC_DISCUSSION_AUTH_MODE
ARG NEXT_PUBLIC_EXTENSION_GATE_ENABLED
ARG NEXT_PUBLIC_EXTENSION_ALLOWLIST
ARG NEXT_PUBLIC_EXTENSION_CONTRIBUTION_ENGINE_URL

ENV NEXT_PUBLIC_GRAPHQL_URL=${NEXT_PUBLIC_GRAPHQL_URL}
ENV NEXT_PUBLIC_QUERY_API_BASE_URL=${NEXT_PUBLIC_QUERY_API_BASE_URL}
ENV NEXT_PUBLIC_SIDECAR_BASE_URL=${NEXT_PUBLIC_SIDECAR_BASE_URL}
ENV NEXT_PUBLIC_COLLAB_WS_URL=${NEXT_PUBLIC_COLLAB_WS_URL}
ENV NEXT_PUBLIC_SOLANA_RPC_URL=${NEXT_PUBLIC_SOLANA_RPC_URL}
ENV NEXT_PUBLIC_IDENTITY_REGISTRY_NAME=${NEXT_PUBLIC_IDENTITY_REGISTRY_NAME}
ENV NEXT_PUBLIC_IDENTITY_PROGRAM_ID=${NEXT_PUBLIC_IDENTITY_PROGRAM_ID}
ENV NEXT_PUBLIC_CONTENT_PROGRAM_ID=${NEXT_PUBLIC_CONTENT_PROGRAM_ID}
ENV NEXT_PUBLIC_ACCESS_PROGRAM_ID=${NEXT_PUBLIC_ACCESS_PROGRAM_ID}
ENV NEXT_PUBLIC_EVENT_PROGRAM_ID=${NEXT_PUBLIC_EVENT_PROGRAM_ID}
ENV NEXT_PUBLIC_FACTORY_PROGRAM_ID=${NEXT_PUBLIC_FACTORY_PROGRAM_ID}
ENV NEXT_PUBLIC_MESSAGING_PROGRAM_ID=${NEXT_PUBLIC_MESSAGING_PROGRAM_ID}
ENV NEXT_PUBLIC_CIRCLES_PROGRAM_ID=${NEXT_PUBLIC_CIRCLES_PROGRAM_ID}
ENV NEXT_PUBLIC_CONTRIBUTION_ENGINE_PROGRAM_ID=${NEXT_PUBLIC_CONTRIBUTION_ENGINE_PROGRAM_ID}
ENV NEXT_PUBLIC_AUTH_SESSION_REQUIRE_SIGNATURE=${NEXT_PUBLIC_AUTH_SESSION_REQUIRE_SIGNATURE}
ENV NEXT_PUBLIC_DISCUSSION_AUTH_MODE=${NEXT_PUBLIC_DISCUSSION_AUTH_MODE}
ENV NEXT_PUBLIC_EXTENSION_GATE_ENABLED=${NEXT_PUBLIC_EXTENSION_GATE_ENABLED}
ENV NEXT_PUBLIC_EXTENSION_ALLOWLIST=${NEXT_PUBLIC_EXTENSION_ALLOWLIST}
ENV NEXT_PUBLIC_EXTENSION_CONTRIBUTION_ENGINE_URL=${NEXT_PUBLIC_EXTENSION_CONTRIBUTION_ENGINE_URL}

RUN npm run build

FROM build-base

WORKDIR /app/sdk
COPY --from=builder /app/sdk/package.json ./package.json
COPY --from=builder /app/sdk/README.md ./README.md
COPY --from=builder /app/sdk/STORAGE_GUIDE.md ./STORAGE_GUIDE.md
COPY --from=builder /app/sdk/dist ./dist

WORKDIR /app/frontend
COPY frontend/package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/frontend/.next ./.next
COPY --from=builder /app/frontend/public ./public

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000

CMD ["npm", "start"]
