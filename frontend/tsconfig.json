{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    ".next-playwright-default/types/**/*.ts",
    ".next-playwright-default/dev/types/**/*.ts",
    ".next-playwright-onboarding/types/**/*.ts",
    ".next-playwright-onboarding/dev/types/**/*.ts",
    ".next-playwright-extension/types/**/*.ts",
    ".next-playwright-extension/dev/types/**/*.ts",
    ".next-playwright-a11y/types/**/*.ts",
    ".next-playwright-a11y/dev/types/**/*.ts",
    ".next-playwright-profile/types/**/*.ts",
    ".next-playwright-profile/dev/types/**/*.ts",
    ".next-playwright-onboarding-only/types/**/*.ts",
    ".next-playwright-onboarding-only/dev/types/**/*.ts",
    ".next-playwright-external-app/types/**/*.ts",
    ".next-playwright-external-app/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "docs/**/*"
  ]
}
